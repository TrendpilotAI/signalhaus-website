# ─── SignalHaus — Environment Variables ─────────────────────────────────────
# Copy this file to .env.local for local development.
# Set all variables in Vercel Dashboard → Settings → Environment Variables.

# ─── Contact Form (Resend) ───────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
# Must be a verified sending domain on Resend (signalhaus.ai)
RESEND_API_KEY=re_your_key_here

# Where to deliver contact form submissions
CONTACT_EMAIL=hello@signalhaus.ai

# ─── Rate Limiting (Upstash Redis) ──────────────────────────────────────────
# Required for persistent rate limiting on Vercel (serverless, no shared memory).
# Create a Redis database at https://console.upstash.com — free tier is fine.
# Without these the app falls back to a per-process in-memory limiter
# (works locally, NOT reliable on Vercel because each invocation is isolated).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ─── Analytics (optional — app works without these) ─────────────────────────
# Google Analytics 4 — https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity — https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_id

# LinkedIn Insight Tag — https://www.linkedin.com/campaignmanager/
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=your_partner_id

# ─── Notifications (optional) ───────────────────────────────────────────────
# Slack Incoming Webhook URL — for lead notifications in Slack
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
